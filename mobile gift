<!-- REFERRALS & EARNINGS PAGE -->
<div id="referrals" class="section">
<h2>Referrals & Earnings</h2>
<p>Your referral code: <b id="myReferralCode"></b></p>
<p>Share your referral link:</p>
<input type="text" id="myReferralLink" readonly style="width:90%; padding:10px;">
<p>Total Referrals: <b id="totalReferrals">0</b></p>
<p>Total Earnings: <b id="totalEarnings">0 PKR</b></p>
<button onclick="copyReferralLink()">Copy Link</button>
</div>

<footer>© 2026 Mobile Gift Club</footer>

<script>
// Generate referral code
function generateReferralCode(name){
    return name.slice(0,3).toUpperCase() + Math.floor(Math.random()*1000);
}

// Initialize localStorage
if(!localStorage.getItem('referralEarnings')){
    localStorage.setItem('referralEarnings', JSON.stringify({}));
}

// Handle join form
document.getElementById('joinForm').addEventListener('submit', function(e){
    e.preventDefault();
    const name = e.target[0].value;
    const referralInput = e.target['referral'].value.trim();
    const userReferralCode = generateReferralCode(name);

    // Show referral message
    let message = `Thank you, ${name}! Your referral code is: ${userReferralCode}.`;
    message += ` Share your referral link: ${window.location.origin + window.location.pathname}?ref=${userReferralCode}`;
    document.getElementById('referralMessage').innerText = message;

    // Handle earnings
    if(referralInput){
        let earningsData = JSON.parse(localStorage.getItem('referralEarnings'));
        if(!earningsData[referralInput]){
            earningsData[referralInput] = 0;
        }
        earningsData[referralInput] += 50; // 50 PKR per referral
        localStorage.setItem('referralEarnings', JSON.stringify(earningsData));
        document.getElementById('earningsMessage').innerText = `Referral code ${referralInput} earned 50 PKR!`;
    }

    // Save user's referral code to localStorage
    localStorage.setItem('myReferralCode', userReferralCode);

    // Prefill URL with referral
    const params = new URLSearchParams(window.location.search);
    if(!params.get('ref')){
        window.history.replaceState({}, '', `${window.location.pathname}?ref=${userReferralCode}`);
    }

    // Update referrals page
    updateReferralsPage();
});

// Prefill referral if visited via link
window.addEventListener('DOMContentLoaded', function(){
    const params = new URLSearchParams(window.location.search);
    const ref = params.get('ref');
    if(ref){
        document.getElementById('referral').value = ref;
    }
    updateReferralsPage();
});

// Update referrals & earnings page
function updateReferralsPage(){
    const myCode = localStorage.getItem('myReferralCode') || "N/A";
    document.getElementById('myReferralCode').innerText = myCode;
    document.getElementById('myReferralLink').value = window.location.origin + window.location.pathname + "?ref=" + myCode;

    const earningsData = JSON.parse(localStorage.getItem('referralEarnings'));
    const total = earningsData[myCode] || 0;
    const count = Math.floor(total / 50);
    document.getElementById('totalReferrals').innerText = count;
    document.getElementById('totalEarnings').innerText = total + " PKR";
}

// Copy referral link
function copyReferralLink(){
    const linkInput = document.getElementById('myReferralLink');
    linkInput.select();
    linkInput.setSelectionRange(0, 99999);
    document.execCommand("copy");
    alert("Referral link copied!");
}
</script>


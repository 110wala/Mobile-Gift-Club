<style>
body{
margin:0;
font-family:Arial;
background:linear-gradient(120deg,#fff5f5,#ffeaea,#ffffff);
}

/* HEADER */
header{
background:linear-gradient(45deg,#c62828,#e53935,#ff5252);
color:white;
text-align:center;
padding:25px;
}
.logo{width:120px;}

/* MENU */
nav{
background:#ff5252;
text-align:center;
padding:12px;
}
nav a{
color:white;
margin:12px;
text-decoration:none;
font-weight:bold;
}
nav a:hover{color:#ffd54f;}

/* SECTIONS */
.section{padding:35px 15px;text-align:center;}

/* HERO */
.hero{background:linear-gradient(45deg,#ff5252,#ff867c);color:white;padding:40px 20px;}

/* PLANS */
.plans{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;margin-top:20px;}
.plan{width:230px;padding:20px;border-radius:12px;box-shadow:0 6px 15px rgba(0,0,0,0.15);transition:0.3s;}
.plan:hover{transform:scale(1.05);}
.basic{background:linear-gradient(135deg,#09e360,#390202);border-top:6px solid #ff5252;}
.standard{background:linear-gradient(135deg,#4e1616,#ffc506);border-top:6px solid #ffc107;}
.platinum{background:linear-gradient(135deg,#c8a2a2,#4f6270);border-top:6px solid #2196f3;}
.plan h3{color:#d32f2f;}

/* BUTTON */
button{background:linear-gradient(45deg,#e53935,#ff5252);color:white;border:none;padding:12px 22px;border-radius:6px;cursor:pointer;font-weight:bold;}

/* FORM */
form{background:white;padding:20px;max-width:320px;margin:auto;border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,0.1);}
input,select{width:95%;padding:10px;margin:8px 0;border:1px solid #ccc;border-radius:5px;}

/* TEAM */
.team{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;margin-top:20px;}
.member{background:white;padding:15px;width:160px;border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,0.1);}
.member img{width:100%;border-radius:10px;}

/* TABLE */
table{margin:auto;border-collapse:collapse;width:90%;max-width:500px;}
th,td{border:1px solid #ddd;padding:10px;}
th{background:#d32f2f;color:white;}

/* FOOTER */
footer{background:#d32f2f;color:white;text-align:center;padding:15px;margin-top:20px;}
</style>
</head>
